# ─────────────────────────────────────────────────────────────────────────
# Frontend image — multi-stage: build with Node, serve static with Nginx.
# Build context: repo root.  Build: docker build -f docker/Dockerfile.frontend .
# ─────────────────────────────────────────────────────────────────────────
FROM node:20-alpine AS build
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install --no-audit --no-fund
COPY frontend/ ./
# VITE_TOKEN_ENDPOINT can be baked at build time; defaults to /api/token
ARG VITE_TOKEN_ENDPOINT=/api/token
ENV VITE_TOKEN_ENDPOINT=$VITE_TOKEN_ENDPOINT
RUN npm run build

FROM nginx:1.27-alpine AS runtime
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
HEALTHCHECK --interval=30s --timeout=3s \
  CMD wget -qO- http://localhost/ >/dev/null 2>&1 || exit 1
CMD ["nginx", "-g", "daemon off;"]
