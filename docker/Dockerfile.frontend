# Multi-stage: build frontend, then add token-server into runtime
FROM node:20-alpine AS build
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install --no-audit --no-fund
COPY frontend/ ./
ARG VITE_TOKEN_ENDPOINT=/api/token
ENV VITE_TOKEN_ENDPOINT=$VITE_TOKEN_ENDPOINT
RUN npm run build

FROM python:3.11-slim AS runtime
# Install nginx + supervisor
RUN apt-get update && apt-get install -y --no-install-recommends nginx supervisor curl \
    && rm -rf /var/lib/apt/lists/*

# Copy frontend build
COPY --from=build /app/dist /usr/share/nginx/html

# Copy token server code
WORKDIR /app
COPY agent/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt
COPY agent/ ./

# Nginx config — proxy to localhost since token-server runs in same container
COPY docker/nginx.conf /tmp/nginx.conf
RUN sed -i 's|http://token-server:8080|http://127.0.0.1:8080|g' /tmp/nginx.conf \
    && cp /tmp/nginx.conf /etc/nginx/sites-enabled/default \
    && rm /etc/nginx/sites-enabled/default 2>/dev/null; \
    cp /tmp/nginx.conf /etc/nginx/conf.d/default.conf

# Supervisor config to run nginx + uvicorn
RUN echo $'[supervisord]\nnodaemon=true\n\n[program:nginx]\ncommand=nginx -g "daemon off;"\nautorestart=true\n\n[program:token-server]\ncommand=uvicorn agent.token_server:app --host 0.0.0.0 --port 8080\nautorestart=true' > /etc/supervisor/conf.d/app.conf

EXPOSE 80 8080
CMD ["supervisord", "-c", "/etc/supervisor/supervisord.conf"]
