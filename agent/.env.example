# ─────────────────────────────────────────────────────────────────────────
# Warrior B.O.S.S. Agent Worker — environment template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────

# --- LiveKit connection (worker side) ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_0123456789abcdef

# Public ws/wss URL the BROWSER should use (token server hands this out).
# In production this is wss://livekit.warriorworld.life
LIVEKIT_PUBLIC_URL=ws://localhost:7880

# --- LLM: Abacus AI (OpenAI-compatible RouteLLM) ---
ABACUS_API_KEY=
ABACUS_BASE_URL=https://routellm.abacus.ai/v1
ABACUS_MODEL=route-llm

# Optional OpenAI fallback (only used if ABACUS_API_KEY is empty)
OPENAI_API_KEY=

# --- Speech-to-Text ---
# "deepgram" (needs DEEPGRAM_API_KEY) or "whisper" (local, CPU heavy)
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2-general

# --- Text-to-Speech (Edge TTS — free, no key required) ---
TTS_VOICE=en-US-GuyNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz

# --- Conversation behaviour ---
MAX_HISTORY_TURNS=10
# AGENT_GREETING=Welcome, Warrior. ...

# --- Token server ---
TOKEN_SERVER_CORS=*
TOKEN_TTL_SECONDS=3600
