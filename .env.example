# ─────────────────────────────────────────────────────────────────────────
# Root environment for docker-compose. Copy to `.env` and fill in.
# Generate LiveKit keys with: ./livekit-server/generate-keys.sh
# ─────────────────────────────────────────────────────────────────────────

# LiveKit credentials (must match livekit-server/livekit.yaml `keys`)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_0123456789abcdef
# URL the browser uses to reach LiveKit (host machine in local dev)
LIVEKIT_PUBLIC_URL=ws://localhost:7880

# LLM — Abacus AI (OpenAI-compatible RouteLLM)
ABACUS_API_KEY=
ABACUS_BASE_URL=https://routellm.abacus.ai/v1
ABACUS_MODEL=route-llm
# Optional OpenAI fallback
OPENAI_API_KEY=

# Speech-to-text
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=

# Text-to-speech (Edge TTS — free)
TTS_VOICE=en-US-GuyNeural
